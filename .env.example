# Production environment — copy to .env and edit.
# Never commit .env — it is gitignored.

# Image tags — updated automatically by deploy-app.sh / deploy-website.sh.
# Set to a specific git SHA to pin a version; 'latest' follows the most recent build.
APP_TAG=latest
WEBSITE_TAG=latest

# Persistent storage path on the host for DataSlicer snapshots.
SNAPSHOT_DIR=/opt/datafeta-data/snapshots

# Hosted DataSlicer defaults to demo mode. Server-side snapshots are read-only,
# debug APIs/UI are disabled, and manual connectors are limited to file upload.
APP_MODE=demo
SNAPSHOT_MODE=readonly
CURATED_SNAPSHOT_DIR=/app/data/snapshots
DEBUG_API_ENABLED=false
DEBUG_UI_ENABLED=false
CONNECTOR_ALLOWLIST=csv

# Internal ClickHouse service for curated demo datasets.
# Data is stored in the Docker-managed volume `clickhouse-data`.
CLICKHOUSE_IMAGE=clickhouse/clickhouse-server:24.8
CLICKHOUSE_DEMO_DATASET_DIR=/opt/datafeta-data/demo-datasets
CLICKHOUSE_DEMO_DATABASES=demo_penguins
CLICKHOUSE_DEMO_USER=demo_readonly
CLICKHOUSE_DEMO_PASSWORD=change-me-clickhouse-demo-password

# Optional predefined demo datasets. Keep secrets and real credentials in .env only.
DEMO_DATASETS_ENABLED=true
# DEMO_DATASETS_JSON=[{"id":"BoxPlots","label":"BoxPlots","description":"boxplot example","database":"tti_dems19d7_TMT_1342","table":"dlFdSchedData","snapshotId":"e9e7ba9c-f375-423b-8a17-683b848d5c61"}]
# DEMO_CLICKHOUSE_HOST defaults to the internal Docker service name `clickhouse`.
# DEMO_CLICKHOUSE_PORT defaults to 8123.
# App credentials are derived from CLICKHOUSE_DEMO_USER / CLICKHOUSE_DEMO_PASSWORD.
